{
  "manifest_version": 2,
  "name": "MyExportToMD",
  "version": "1.0.0",
  "description": "Export the current page or a selected element to a Markdown file.",
  "browser_specific_settings": {
    "gecko": {
      "id": "exporttomarkdown@example.com"
    }
  },
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "background": {
    "scripts": [
      "dist/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/content.js"
      ]
    }
  ],
  "browser_action": {
    "default_title": "Export to Markdown"
  }
}
