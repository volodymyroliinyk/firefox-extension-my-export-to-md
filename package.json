{
  "name": "my-export-to-md",
  "version": "1.0.6",
  "description": "Firefox extension to export full page or selected elements to Markdown file",
  "author": "Volodymyr Oliinyk <volodymyr.oliinyk.name@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/volodymyroliinyk/my-export-to-md#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/volodymyroliinyk/my-export-to-md.git"
  },
  "bugs": {
    "url": "https://github.com/volodymyroliinyk/my-export-to-md/issues"
  },
  "scripts": {
    "lint": "npm run lint:types && npm run lint:tests && npm run lint:webext",
    "lint:bundle": "mkdir -p dist && ./node_modules/.bin/esbuild src/content.ts --bundle --outfile=dist/content.js && ./node_modules/.bin/esbuild src/background.ts --bundle --outfile=dist/background.js",
    "lint:webext": "npm run lint:bundle && ./sh/lint-webext.sh ./",
    "lint:types": "./node_modules/.bin/tsc --noEmit",
    "lint:tests": "./node_modules/.bin/eslint \"tests/**/*.cjs\"",
    "test": "./sh/test.sh",
    "build": "./sh/build.sh",
    "dev": "./sh/dev.sh",
    "release": "./sh/release.sh"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^1.2.0",
    "@types/turndown": "^5.0.4",
    "esbuild": "^0.20.2",
    "turndown": "^7.1.3",
    "typescript": "^5.4.5",
    "web-ext": "^7.11.0"
  }
}
