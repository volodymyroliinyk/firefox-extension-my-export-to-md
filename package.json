{
  "name": "my-export-to-md",
  "version": "1.0.0",
  "description": "Firefox extension to export full page or selected elements to Markdown file",
  "author": "Volodymyr Oliinyk <volodymyr.oliinyk.name@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/volodymyroliinyk/my-export-to-md#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/volodymyroliinyk/my-export-to-md.git"
  },
  "bugs": {
    "url": "https://github.com/volodymyroliinyk/my-export-to-md/issues"
  },
  "scripts": {
    "lint": "./node_modules/.bin/web-ext lint --source-dir ./ --warnings-as-errors --ignore-files \"sh/*\" \"*.zip\" \"node_modules/*\" \".git/*\" \".idea/*\" \"ai_prompts/*\" \"tests/*\" \"src/*\" \"*.md\" \"package-lock.json\" \"package.json\" \"tsconfig.json\"",
    "test": "./sh/test.sh",
    "build": "./sh/build.sh",
    "dev": "./sh/dev.sh",
    "release": "./sh/release.sh"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^1.2.0",
    "@types/turndown": "^5.0.4",
    "esbuild": "^0.20.2",
    "turndown": "^7.1.3",
    "typescript": "^5.4.5",
    "web-ext": "^7.11.0"
  }
}
